[
  {
    "character": "the silent",
    "card_name": "Abrasive",
    "note": "Sly: plays for free when discarded. 3-cost applies Thorns + Dexterity. Effective cost is 0 energy with discard outlets (Acrobatics, Survivor, Dagger Throw). High combined stat value when triggered via Sly."
  },
  {
    "character": "the silent",
    "card_name": "Accelerant",
    "note": "Power: Poison damage triggers an extra time at end of turn. Example: enemy has 20 Poison → normally takes 20 damage, with Accelerant takes 20+19=39 damage. Doubles effective Poison damage that turn. Stacks with more Poison sources (Noxious Fumes, Deadly Poison, Bubble Bubble) for higher burst."
  },
  {
    "character": "the silent",
    "card_name": "Accuracy",
    "note": "Power: +4 damage to all Shivs per copy. Base Shiv = 4 dmg → 8 with 1 copy, 12 with 2 copies. ONLY buffs Shiv cards — does NOT affect Ricochet, Dagger Spray, or other multi-hit attacks. Stacks: multiple copies multiply value linearly with Shiv generators (Blade Dance, Up My Sleeve, Infinite Blades, Fan of Knives)."
  },
  {
    "character": "the silent",
    "card_name": "Acrobatics",
    "note": "1-cost: draw 3 discard 1. The discard is a card effect, triggering Sly cards (Reflex, Tactician, Untouchable) for free plays. Cycles through deck while generating discard synergy value. Functions well without upgrade. Multiple copies improve cycle speed."
  },
  {
    "character": "the silent",
    "card_name": "Adrenaline",
    "note": "0-cost: draw 2 + gain 2 energy. Net +2 energy and +2 cards for 0 cost — effectively free. Exhaust after use. No build requirements — universally functional in any deck."
  },
  {
    "character": "the silent",
    "card_name": "Afterimage",
    "note": "Power: gain 1 Block per card played. Scales with cards-per-turn — Shiv generators (Blade Dance = 3 Shivs = 3 Block), 0-cost cards, and draw engines increase its output. Provides passive Block without spending energy on Block cards."
  },
  {
    "character": "the silent",
    "card_name": "Anticipate",
    "note": "0-cost: gain 3 Dexterity this turn only. Temporary — expires at end of turn (unlike Footwork which is permanent). Each Block card played this turn gains +3 Block. Best when multiple Block cards are played in the same turn."
  },
  {
    "character": "the silent",
    "card_name": "Assassinate",
    "note": "0-cost: 10 damage + 1 Vulnerable. Exhaust. Applies Vulnerable (50% more Attack damage) at zero energy, enabling follow-up attacks to hit harder this turn."
  },
  {
    "character": "the silent",
    "card_name": "Backflip",
    "note": "1-cost: block + draw 2. Defends and cycles simultaneously. The draw does not trigger Sly (draw is not discard). Pairs with Dexterity (Footwork) for scaled Block."
  },
  {
    "character": "the silent",
    "card_name": "Backstab",
    "note": "0-cost Innate: 11 damage. Guaranteed in opening hand every combat. Exhaust after use. Provides free first-turn damage with no energy cost."
  },
  {
    "character": "the silent",
    "card_name": "Blade Dance",
    "note": "1-cost: generates 3 Shivs into hand (each Shiv = 0-cost 4 damage, Exhaust). Total output: 12 damage for 1 energy. Combos: Accuracy (+4 per Shiv), Knife Trap (replays exhausted Shivs), Afterimage (3 Block from 3 Shivs played)."
  },
  {
    "character": "the silent",
    "card_name": "Blur",
    "note": "Block carries over between turns instead of resetting to 0. Enables accumulating Block walls over multiple turns. Pairs with consistent Block generation (Footwork, Backflip, Afterimage)."
  },
  {
    "character": "the silent",
    "card_name": "Bouncing Flask",
    "note": "2-cost: applies 9 total Poison (3 hits × 3 Poison). Splits across enemies in multi-enemy fights (random targeting). Compare: Bubble Bubble (1-cost, 9 Poison, single target) is more efficient per energy."
  },
  {
    "character": "the silent",
    "card_name": "Bubble Bubble",
    "note": "1-cost: applies 9 Poison to a single target. Best when you already have poison support; treat it as poison density/payoff, not a reason to enter poison by itself."
  },
  {
    "character": "the silent",
