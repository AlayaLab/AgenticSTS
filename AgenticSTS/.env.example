# AgenticSTS environment template.
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# Only the REQUIRED section must be populated to start the agent.

# ══════════════════════════════════════════════════════════════════
#   REQUIRED — at least one LLM path must be configured
# ══════════════════════════════════════════════════════════════════

# ── Anthropic (Claude) ──
# Used for web search and any Anthropic-native SDK calls.
# If you use a proxy (e.g. proxy.example.com), set ANTHROPIC_BASE_URL; otherwise leave
# empty to hit api.anthropic.com directly.
ANTHROPIC_BASE_URL=
ANTHROPIC_API_KEY=

# Opus-specific credentials (when the main relay lacks opus support).
STS2_OPUS_API_KEY=
STS2_OPUS_BASE_URL=
STS2_ANTHROPIC_DISABLE_CACHE=true

# ── Model-family keys on an OpenAI-compatible relay ──
# If you route through a proxy (e.g. proxy.example.com / proxy.example.com) that exposes multiple
# model families under different keys, set them here. The router auto-picks the
# right key by model name.
STS2_GPT_BASE_URL=
STS2_GPT_API_KEY=
STS2_GEMINI_BASE_URL=
STS2_GEMINI_API_KEY=
# Qwen family: DashScope (Alibaba Cloud official) is preferred — it honors
# `enable_thinking` (SiliconFlow ignores thinking_budget). Base URL:
#   https://dashscope.aliyuncs.com/compatible-mode/v1
STS2_QWEN_BASE_URL=
STS2_QWEN_API_KEY=
# DeepSeek V4 family (deepseek-v4-flash, deepseek-v4-pro). Official endpoint
# at api.deepseek.com — OpenAI-compatible with thinking toggle
# (`thinking: {type: enabled/disabled}` + `reasoning_effort: high|max`).
# Fast tier = thinking off, strategic tier = thinking high (max is ~4× slower,
# unusable per-turn per 2026-04-24 smoke test).
# Analysis tier routes to gemini-3.1-pro-preview (requires STS2_GEMINI_API_KEY).
STS2_DEEPSEEK_BASE_URL=https://api.deepseek.com
STS2_DEEPSEEK_API_KEY=

# ══════════════════════════════════════════════════════════════════
#   Model family (single-switch routing)
# ══════════════════════════════════════════════════════════════════
# Pick a family and all tiers (fast/strategic/analysis/evolution) resolve
# from `config._MODEL_FAMILIES`. Families: gemini (default), gpt, qwen,
# claude, deepseek. Weak gameplay families (qwen, deepseek) route their
# `analysis` tier to gemini-3.1-pro-preview so postrun still runs — requires
# STS2_GEMINI_API_KEY to be set.
STS2_MODEL_FAMILY=gemini

# Per-tier family override (mix families, e.g. gemini-strategic + gpt-fast).
# Leave empty to inherit STS2_MODEL_FAMILY.
# STS2_MODEL_FAMILY_FAST=
# STS2_MODEL_FAMILY_STRATEGIC=
# STS2_MODEL_FAMILY_ANALYSIS=

# Order of fallback families when the primary family's model fails.
STS2_MODEL_FAMILY_FALLBACK=gemini,gpt,qwen,claude

# Per-family effort overrides (e.g. run qwen strategic at "high" while fast
# stays at "medium"). Precedence: per-family > STS2_THINK_EFFORT_<TIER> >
# registry default.
# STS2_QWEN_EFFORT_STRATEGIC=high
# STS2_GEMINI_EFFORT_FAST=low

# ══════════════════════════════════════════════════════════════════
#   Tier overrides (escape hatches; leave blank to use registry defaults)
# ══════════════════════════════════════════════════════════════════
# Tier usage:
#   fast       → map step, hand_select, treasure
#   strategic  → combat plans, rest, shop, event, card reward/select, route
#   analysis   → post-run reflection, distillation, guide consolidation
#   evolution  → self-evolution tool-use loop

# Direct model overrides (beat the family registry).
# STS2_FAST_MODEL=gemini-3.1-flash-lite-preview
# STS2_STRATEGIC_MODEL=gemini-3.1-pro-preview
# STS2_ANALYSIS_MODEL=gemini-3.1-pro-preview
# STS2_EVOLUTION_MODEL=gemini-3.1-pro-preview

# Fallback chains (comma-separated). Leave blank to auto-derive from the
# family-fallback order.
# STS2_FAST_FALLBACK_MODELS=
# STS2_STRATEGIC_FALLBACK_MODELS=
# STS2_ANALYSIS_FALLBACK_MODELS=
# STS2_EVOLUTION_FALLBACK_MODELS=

STS2_WEB_SEARCH_MODEL=claude-opus-4-6
STS2_MONITOR_SUMMARY_MODEL=gpt-5.4-mini

# Thinking effort per tier (global — overridden by per-family STS2_<FAMILY>_EFFORT_<TIER>).
STS2_THINK_EFFORT_FAST=low
STS2_THINK_EFFORT_STRATEGIC=medium
STS2_THINK_EFFORT_ANALYSIS=high
STS2_THINK_TYPE=adaptive

# ══════════════════════════════════════════════════════════════════
#   Features
# ══════════════════════════════════════════════════════════════════

# Post-run pipeline master switch. When false, _safe_post_run() skips
# memory extraction, skill discovery, distillation, guide consolidation,
# and evolution. Gameplay-time JSONL logs still write. Also auto-disables
# when the active family has no `analysis` tier (e.g. qwen).
STS2_POSTRUN_ENABLED=true

# Post-run self-evolution (writes to L4 memory / L5 skills / dynamic tools).
# Gated by STS2_POSTRUN_ENABLED.
STS2_EVOLUTION_ENABLED=true

# Enable web search tool (uses Anthropic SDK).
STS2_WEB_SEARCH=true

# Enable the FastAPI WebSocket monitor dashboard on port 8081.
STS2_MONITOR_ENABLED=true
STS2_MONITOR_SUMMARY=false

# Enable boss-replay skill A/B evaluation. Keep false until live smoke confirms.
STS2_SKILL_EVAL=false

# Enable write-gate judge-verdict reaping (ADD/UPDATE/MERGE/REJECT). Default
# false preserves observation-mode persistence; flip true after live smoke.
STS2_WRITE_GATE_REAP_ENABLED=false

# Core subsystem toggles (default on; CLI flags --no-memory --no-skills override).
STS2_MEMORY_ENABLED=true
STS2_SKILLS_ENABLED=true

# ══════════════════════════════════════════════════════════════════
#   MCP / Game connection
# ══════════════════════════════════════════════════════════════════

# C# mod HTTP endpoint (exposed by AgenticSTS-Mod (this monorepo) when the game is running).
# Default 8128 chosen to avoid Clash for Windows / common HTTP proxies on 8080.
STS2_MCP_URL=http://localhost:8128
STS2_MCP_TIMEOUT=30.0
STS2_SSE_ENABLED=true
STS2_ACTION_DELAY=0.6
STS2_MONITOR_PORT=8081

# Override data dir if you want state stored somewhere outside the repo.
# STS2_DATA_DIR=data

# ══════════════════════════════════════════════════════════════════
#   OpenAI-compatible relay tuning (optional)
# ══════════════════════════════════════════════════════════════════

STS2_OPENAI_COMPAT_HEDGE_ENABLED=true
STS2_OPENAI_COMPAT_TIMEOUT_SEC=600
STS2_OPENAI_COMPAT_FIRST_CHUNK_DEADLINE_SEC=15
STS2_OPENAI_COMPAT_FAILOVER_COOLDOWN_SEC=0
# Per-tier read timeout. Strategic default 120s (covers Gemini 3.1 Pro thinking
# p99=70s, max=118.6s in 24h sample). Fast default 45s (just above fast p99=44s
# and well under strategic floor) so stuck connections die in 45s instead of
# inheriting the strategic timeout.
STS2_OPENAI_COMPAT_READ_TIMEOUT_SEC=120
STS2_OPENAI_COMPAT_FAST_READ_TIMEOUT_SEC=45

# Separate relay for post-run calls (leave empty to share with gameplay relay).
STS2_POSTRUN_OPENAI_COMPAT_BASE_URL=
STS2_POSTRUN_OPENAI_COMPAT_API_KEY=

# ══════════════════════════════════════════════════════════════════
#   Compatibility flags
# ══════════════════════════════════════════════════════════════════

# Required for some AWS-backed relays. Leave default unless you know otherwise.
CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=true
